%%% Glossary and Acronyms (Glossario e Acronimi) %%%

\setglossarystyle{long} % Stile del glossario (impostato come tabella lunga a due colonne)
\setlength\LTleft{-6pt} % Margine sinistro della tabella
\setlength\LTright{0pt} % Margine destro della tabella
\setlength\glsdescwidth{0.94\hsize} % Larghezza della colonna con la descrizione del termine

\renewcommand{\glsnamefont}[1]{\textbf{#1}} % Formatta la sigla o il termine in grassetto

% Personalizzazione dei numeri di pagina accanto alle voci del glossario
% Usa "p." (valido sia per "page" che per "pagina") e applica il colore primario (Unibo Red) al numero
\renewcommand{\glossaryentrynumbers}[1]{%
	\textit{(p. \textcolor{maincolor}{#1})}%
}