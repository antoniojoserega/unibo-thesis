%%% Code Highlighting %%%
\newenvironment{code}{\captionsetup{type=listing}}{}

% --- Gestione Lingua per i blocchi di codice ---
\ifthenelse{\equal{\LanguageOption}{italian}}{%
	\SetupFloatingEnvironment{listing}{name=Listato,within=none}
}{%
	\SetupFloatingEnvironment{listing}{name=Listing,within=none}
}

\captionsetup[listing]{position=above,skip=-6pt}
\newenvironment{longlisting}{\bigskip\medskip\captionsetup{type=listing}}{}

% --- Configurazione Minted (Libreria per stampare il codice) ---
% Define a new and improved minted style.
\setminted{
	frame=lines,
	framesep=2mm,
	baselinestretch=1.2,
	fontsize=\footnotesize,
	linenos,
	tabsize=4,
	breaklines=true,
	breakanywhere=true
}

% Change line number color to gray
\renewcommand{\theFancyVerbLine}{%
	\scriptsize\textcolor[rgb]{0.7,0.7,0.7}{\arabic{FancyVerbLine}}%
}