%%% Document colors - Dynamic per University %%%

% --- Unibo (Alma Mater Studiorum - Bologna) ---
\ifthenelse{\equal{\UniversityOption}{unibo}}{
	\definecolor{unibored}{RGB}{177, 0, 36}      % Pantone 186 C - mantenuto per compatibilità
	\definecolor{maincolor}{RGB}{177, 0, 36}
	\definecolor{frontpagedark}{HTML}{1c1c1c}
}{
	% Fallback neutro
	\definecolor{unibored}{RGB}{0, 0, 0}
	\definecolor{maincolor}{RGB}{0, 0, 0}
	\definecolor{frontpagedark}{HTML}{1c1c1c}
}

\colorlet{chapterdarkred}{maincolor}
\colorlet{chaptergray}{gray!80!white}

% Colors used in the custom block environment
\definecolor{note}{HTML}{0969da}
\definecolor{tip}{HTML}{1a7f37}
\definecolor{warning}{HTML}{9a6700}
\definecolor{todo}{HTML}{B10024}