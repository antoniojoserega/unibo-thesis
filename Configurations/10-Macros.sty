%%% Document Macros and Extras (Unibo Edition) %%%

% --- Blank Page Management ---
% Blank page with a warning indicating it is intentionally left blank.
\newcommand\blankpage{
	\clearpage
	\thispagestyle{empty}%
	\vspace*{\fill}
	\begin{center}
		\ifthenelse{\equal{\LanguageOption}{italian}}{%
			\textcolor{gray!50}{\textit{Pagina intenzionalmente lasciata bianca.}}
		}{%
			\textcolor{gray!50}{\textit{This page intentionally left blank.}}
		}
	\end{center}
	\vspace*{\fill}
	\clearpage
} 

% Command that will combine a plain page style and a blank one.
\newcommand{\plainblankpage}{\thispagestyle{plain}\blankpage}

% Logic to add or omit a blank page. 
% Semplificata per funzionare sempre senza errori su GitHub Actions
\newcommand{\MediaOptionLogic}{%
	\clearpage
}
\newcommand{\MediaOptionLogicAcr}{%
	\clearpage
}
\newcommand{\MediaOptionLogicBlank}{%
	\blankpage
}
\newcommand{\MediaOptionLogicAnnexes}{%
	\clearpage
}


% --- Guide and Info Blocks ---
% Indicates that a writing guide will be displayed.
\newcommand{\guideinfo}[1]{%
	\ifthenelse{\equal{\LanguageOption}{italian}}{%
		\noindent\textcolor{unibored}{\faInfoCircle\ \textbf{Guida alla Scrittura}}%
	}{%
		\noindent\textcolor{unibored}{\faInfoCircle\ \textbf{Writing Guidance}}%
	}
	\\[.55em]%
	\noindent #1%
}

\newcommand{\exampleinfo}[1]{%
	\ifthenelse{\equal{\LanguageOption}{italian}}{%
		\noindent\textcolor{black}{\faInfoCircle\ \textbf{Esempio di Utilizzo}}%
	}{%
		\noindent\textcolor{black}{\faInfoCircle\ \textbf{Example of Use}}%
	}
	\\[.55em]%
	\noindent #1%
}

% --- Landscape Mode ---
% Landscape mode - the proper way!
\def\ifGm@preamble#1{\@firstofone}
\appto\restoregeometry{%
	\pdfpagewidth=\paperwidth
	\pdfpageheight=\paperheight}
\apptocmd\newgeometry{%
	\pdfpagewidth=\paperwidth
	\pdfpageheight=\paperheight}{}{}
\newenvironment{landscapemode}[2]{%
	\newgeometry{paperwidth=#1,paperheight=#2,hmargin=3cm,vmargin=5cm,top=3cm,landscape}
	\fancyheadoffset{0pt}
}{%
	\restoregeometry
	\fancyheadoffset{0pt}
}

% --- Custom Quote Blocks ---
% Custom Markdown quote block implementation in LaTeX.
\newtcolorbox[auto counter,number within=section]{block}[1][]{
	enhanced jigsaw,
	coltitle=#1,
	colback=#1!08!white,
	colframe=#1!08!white,
	fonttitle=\latofont\bfseries,
	sharp corners=west,
	detach title,
	borderline west={.85mm}{0pt}{#1},
	pad at break=1mm,
	top=4mm,
	bottom=4mm,
	title={\ifstrequal{#1}{todo}{To-Do}{\capitalisewords{#1}}},
	code={\ifdefempty{\tcbtitletext}{}{\tcbset{before upper={\tcbtitle\par\medskip}}}},
}

% --- Autoref Capitalization ---
% Capitalise the first letter in '\autoref' for both English and Italian.
\addto\extrasenglish{\def\figureautorefname{Figure}}
\addto\extrasenglish{\def\chapterautorefname{Chapter}}
\addto\extrasenglish{\def\sectionautorefname{Section}}
\addto\extrasenglish{\def\subsectionautorefname{Section}}
\addto\extrasenglish{\def\tableautorefname{Table}}
\addto\extrasenglish{\def\appendixautorefname{Appendix}}

\addto\extrasitalian{\def\figureautorefname{Figura}}
\addto\extrasitalian{\def\chapterautorefname{Capitolo}}
\addto\extrasitalian{\def\sectionautorefname{Sezione}}
\addto\extrasitalian{\def\subsectionautorefname{Sezione}}
\addto\extrasitalian{\def\tableautorefname{Tabella}}
\addto\extrasitalian{\def\appendixautorefname{Appendice}}

% --- AI Prompts (Opzionale) ---
\NewDocumentCommand{\prompt}{o m}{%
	\ifthenelse{\equal{\LanguageOption}{italian}}{%
		\IfNoValueTF{#1}
		{\noindent\textbf{Prompt:} #2}
		{\noindent\textbf{Prompt #1:} #2}
	}{%
		\IfNoValueTF{#1}
		{\noindent\textbf{Prompt:} #2}
		{\noindent\textbf{Prompt #1:} #2}
	}
}

\NewDocumentCommand{\aioutput}{o m}{%
	\ifthenelse{\equal{\LanguageOption}{italian}}{%
		\IfNoValueTF{#1}
		{\noindent\textbf{Risposta:} #2}
		{\noindent\textbf{Risposta #1:} #2}
	}{%
		\IfNoValueTF{#1}
		{\noindent\textbf{Output:} #2}
		{\noindent\textbf{Output #1:} #2}
	}
}